<div class="wfrp3e-hud-container">
  {{#if isGM}}
    <div class="wfrp3e-hud-header">
      <h2>Party HUD</h2>
      <button class="add-xp-btn" title="Add 1 XP to all players"><i class="fas fa-star"></i> Give 1 XP to All</button>
    </div>
    <div class="wfrp3e-hud-grid">
      {{#each characters}}
        <div class="wfrp3e-hud-character" data-actor-id="{{this.id}}">
          <div class="character-name">{{this.name}}</div>
          
          <div class="stat-row">
            <label>HP:</label>
            <div class="stat-controls">
              <button class="stat-btn minus" data-stat="system.wounds.value" data-action="decrease"><i class="fas fa-minus"></i></button>
              <input type="number" class="stat-input hp-input" data-stat="system.wounds.value" value="{{this.system.wounds.value}}" min="0" max="{{this.system.wounds.max}}" />
              <button class="stat-btn plus" data-stat="system.wounds.value" data-action="increase"><i class="fas fa-plus"></i></button>
            </div>
            <span> / {{this.system.wounds.max}}</span>
          </div>

          <div class="stat-row stance-row">
            <label title="Stance Level">Stance:</label>
            <div class="stat-controls stance-controls">
              <a class="stat-btn stance-btn cons-btn" data-stat="system.stance.current" data-action="decrease" title="Make more Conservative">Cons</a>
              <input type="number" class="stat-input stance-input {{stanceColorClass this.system.stance.current}}" data-stat="system.stance.current" value="{{abs this.system.stance.current}}" min="0" />
              <a class="stat-btn stance-btn reck-btn" data-stat="system.stance.current" data-action="increase" title="Make more Reckless">Reck</a>
            </div>
          </div>

          <div class="stat-row">
            <label>Stress:</label>
            <div class="stat-controls">
              <button class="stat-btn minus" data-stat="system.impairments.stress" data-action="decrease"><i class="fas fa-minus"></i></button>
              <input type="number" class="stat-input" data-stat="system.impairments.stress" value="{{this.system.impairments.stress}}" min="0" />
              <button class="stat-btn plus" data-stat="system.impairments.stress" data-action="increase"><i class="fas fa-plus"></i></button>
            </div>
          </div>

          <div class="stat-row">
            <label>Fatigue:</label>
            <div class="stat-controls">
              <button class="stat-btn minus" data-stat="system.impairments.fatigue" data-action="decrease"><i class="fas fa-minus"></i></button>
              <input type="number" class="stat-input" data-stat="system.impairments.fatigue" value="{{this.system.impairments.fatigue}}" min="0" />
              <button class="stat-btn plus" data-stat="system.impairments.fatigue" data-action="increase"><i class="fas fa-plus"></i></button>
            </div>
          </div>
          
          <div class="stat-row">
            <label>Fortune:</label>
            <div class="stat-controls">
              <button class="stat-btn minus" data-stat="system.fortune.value" data-action="decrease"><i class="fas fa-minus"></i></button>
              <input type="number" class="stat-input" data-stat="system.fortune.value" value="{{this.system.fortune.value}}" min="0" />
              <button class="stat-btn plus" data-stat="system.fortune.value" data-action="increase"><i class="fas fa-plus"></i></button>
            </div>
          </div>
        </div>
      {{/each}}
    </div>
  {{else}}
    {{#if character}}
      <div class="wfrp3e-hud-character single" data-actor-id="{{character.id}}">
        <div class="character-name">{{character.name}}</div>
        
        <div class="stat-row">
          <label>HP:</label>
          <div class="stat-controls">
            <button class="stat-btn minus" data-stat="system.wounds.value" data-action="decrease"><i class="fas fa-minus"></i></button>
            <input type="number" class="stat-input hp-input" data-stat="system.wounds.value" value="{{character.system.wounds.value}}" min="0" max="{{character.system.wounds.max}}" />
            <button class="stat-btn plus" data-stat="system.wounds.value" data-action="increase"><i class="fas fa-plus"></i></button>
          </div>
          <span> / {{character.system.wounds.max}}</span>
        </div>

        <div class="stat-row stance-row">
          <label title="Stance Level">Stance:</label>
          <div class="stat-controls stance-controls">
            <a class="stat-btn stance-btn cons-btn" data-stat="system.stance.current" data-action="decrease" title="Make more Conservative">Cons</a>
            <input type="number" class="stat-input stance-input {{stanceColorClass character.system.stance.current}}" data-stat="system.stance.current" value="{{abs character.system.stance.current}}" min="0" />
            <a class="stat-btn stance-btn reck-btn" data-stat="system.stance.current" data-action="increase" title="Make more Reckless">Reck</a>
          </div>
        </div>

        <div class="stat-row">
          <label>Stress:</label>
          <div class="stat-controls">
            <button class="stat-btn minus" data-stat="system.impairments.stress" data-action="decrease"><i class="fas fa-minus"></i></button>
            <input type="number" class="stat-input" data-stat="system.impairments.stress" value="{{character.system.impairments.stress}}" min="0" />
            <button class="stat-btn plus" data-stat="system.impairments.stress" data-action="increase"><i class="fas fa-plus"></i></button>
          </div>
        </div>

        <div class="stat-row">
          <label>Fatigue:</label>
          <div class="stat-controls">
            <button class="stat-btn minus" data-stat="system.impairments.fatigue" data-action="decrease"><i class="fas fa-minus"></i></button>
            <input type="number" class="stat-input" data-stat="system.impairments.fatigue" value="{{character.system.impairments.fatigue}}" min="0" />
            <button class="stat-btn plus" data-stat="system.impairments.fatigue" data-action="increase"><i class="fas fa-plus"></i></button>
          </div>
        </div>
        
        <div class="stat-row">
          <label>Fortune:</label>
          <div class="stat-controls">
            <button class="stat-btn minus" data-stat="system.fortune.value" data-action="decrease"><i class="fas fa-minus"></i></button>
            <input type="number" class="stat-input" data-stat="system.fortune.value" value="{{character.system.fortune.value}}" min="0" />
            <button class="stat-btn plus" data-stat="system.fortune.value" data-action="increase"><i class="fas fa-plus"></i></button>
          </div>
        </div>
      </div>
    {{else}}
      <div class="no-character">No character assigned. Please assign a character to your user to use the HUD.</div>
    {{/if}}
  {{/if}}
</div>
